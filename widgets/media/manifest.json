{
  "id": "ws.stock.media",
  "name": "Now Playing",
  "author": "Waveshare Widgets",
  "version": "1.2.0",
  "description": "Now-playing media with album art, progress bar, and touch transport controls.",
  "min_api_version": 1,
  "supported_slots": [
    "half",
    "full"
  ],
  "properties": [
    {
      "name": "accentColor",
      "label": "Accent Color",
      "type": "color",
      "default": "#00d4ff"
    },
    {
      "name": "bgStyle",
      "label": "Background",
      "type": "select",
      "options": [
        "solid",
        "glass",
        "transparent"
      ],
      "default": "solid"
    }
  ]
}
