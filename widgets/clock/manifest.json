{
  "id": "ws.stock.clock",
  "name": "Clock",
  "author": "Waveshare Widgets",
  "version": "1.2.0",
  "description": "Large digital clock with date.",
  "min_api_version": 1,
  "supported_slots": [
    "quarter",
    "half",
    "full"
  ],
  "properties": [
    {
      "name": "accentColor",
      "label": "Accent Color",
      "type": "color",
      "default": "#e8ecf2"
    },
    {
      "name": "hour12",
      "label": "12-hour Format",
      "type": "select",
      "options": [
        "off",
        "on"
      ],
      "default": "off"
    },
    {
      "name": "showSeconds",
      "label": "Show Seconds",
      "type": "select",
      "options": [
        "on",
        "off"
      ],
      "default": "on"
    },
    {
      "name": "bgStyle",
      "label": "Background",
      "type": "select",
      "options": [
        "solid",
        "glass",
        "transparent"
      ],
      "default": "solid"
    },
    {
      "name": "timeColor",
      "label": "Time color",
      "type": "color",
      "default": "#e8ecf2",
      "group": "Text"
    },
    {
      "name": "timeSize",
      "label": "Time size",
      "type": "slider",
      "min": 50,
      "max": 200,
      "step": 5,
      "default": 100,
      "group": "Text"
    },
    {
      "name": "dateColor",
      "label": "Date color",
      "type": "color",
      "default": "#7d8697",
      "group": "Text"
    },
    {
      "name": "dateSize",
      "label": "Date size",
      "type": "slider",
      "min": 50,
      "max": 200,
      "step": 5,
      "default": 100,
      "group": "Text"
    }
  ]
}
